<suite name="SwagLabs Automation Suite">
    <listeners>
        <listener class-name="com.framework.core.TestListener" />
    </listeners>
        <test name="verifySuccessfulLoginRedirectsToInventory">
            <classes>
                <class name="com.swaglabs.tests.LoginTest">
                    <methods>
                        <include name="verifySuccessfulLoginRedirectsToInventory"/>
                    </methods>
                </class>
            </classes>
        </test>
    <test name="verifyErrorMessageWhenLoginIsNotSuccessful">
        <classes>
            <class name="com.swaglabs.tests.LoginTest">
                <methods>
                    <include name="verifyErrorMessageWhenLoginIsNotSuccessful"/>
                </methods>
            </class>
        </classes>
    </test>
    <test name="TC-05: verifyProductCatalogCountAndBrandingConsistency">
        <classes>
            <class name="com.swaglabs.tests.CatalogTest">
                <methods>
                    <include name="verifyProductCatalogCountAndBrandingConsistency"/>
                </methods>
            </class>
        </classes>
    </test>
    <test name="TC-06: verifyHighToLowPriceSortingLogic">
        <classes>
            <class name="com.swaglabs.tests.CatalogTest">
                <methods>
                    <include name="verifyHighToLowPriceSortingLogic"/>
                </methods>
            </class>
        </classes>
    </test>
    <test name="TC-12: verifyProductDetailsMatchCatalogInformation">
        <classes>
            <class name="com.swaglabs.tests.CatalogTest">
                <methods>
                    <include name="verifyProductDetailsMatchCatalogInformation"/>
                </methods>
            </class>
        </classes>
    </test>
    <test name="TC-07: verifyHighestPriceItemCanBeAddedToCart">
        <classes>
            <class name="com.swaglabs.tests.ShoppingCartTest">
                <methods>
                    <include name="verifyHighestPriceItemCanBeAddedToCart"/>
                </methods>
            </class>
        </classes>
    </test>
    <test name ="TC-08: verifyCartBadgeUpdatesWhenProductIsAdded">
        <classes>
            <class name ="com.swaglabs.tests.ShoppingCartTest">
                <methods>
                    <include name ="verifyCartBadgeUpdatesWhenProductIsAdded"/>
                </methods>
            </class>
        </classes>
    </test>
    <test name ="TC-09: verifyCheckoutTotalsAndTaxCalculationsAreAccurate">
        <classes>
            <class name ="com.swaglabs.tests.CheckoutTest">
                <methods>
                    <include name ="verifyCheckoutTotalsAndTaxCalculationsAreAccurate"/>
                </methods>
            </class>
        </classes>
    </test>
    <test name ="TC-10: verifyCheckoutFormValidationMessagesForMissingFields">
        <classes>
            <class name ="com.swaglabs.tests.CheckoutTest">
                <methods>
                    <include name ="verifyCheckoutFormValidationMessagesForMissingFields"/>
                </methods>
            </class>
        </classes>
    </test>
</suite>

